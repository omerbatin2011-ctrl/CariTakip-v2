# DAL ERP Mobil API ortam değişkenleri

# Ortam: development | production | prod | canli | live
DAL_ERP_ENV=production

# API bind ayarları
DAL_ERP_API_HOST=0.0.0.0
DAL_ERP_API_PORT=8000

# CORS varsayılan olarak kapalıdır.
# Mobil Flutter / Windows Flutter için genellikle gerekmez.
# Tarayıcıdan test gerekiyorsa sadece gerekli adresleri yaz.
# Örnek: DAL_ERP_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
DAL_ERP_ALLOWED_ORIGINS=

# Servis token varsayılan kapalıdır. admin/1234 veya admin-token kullanılmaz.
# Çok özel otomasyon gerekiyorsa ikisini birlikte aç:
# DAL_ERP_ALLOW_SERVICE_TOKEN=1
# DAL_ERP_ADMIN_TOKEN=buraya-guclu-rastgele-token
DAL_ERP_ALLOW_SERVICE_TOKEN=0
DAL_ERP_ADMIN_TOKEN=

# API oturum token süresi, saniye. Varsayılan 12 saat.
DAL_ERP_API_TOKEN_TTL=43200

# Login koruması
DAL_ERP_LOGIN_MAX_ATTEMPTS=5
DAL_ERP_LOGIN_BLOCK_SECONDS=900

# Şifreli yedek için opsiyonel parola. Boşsa araç parola sorar.
DAL_ERP_BACKUP_PASSWORD=

# Eski düz metin kullanıcı şifreleri kabul edilmesin. Geçiş için geçici 1 yapılabilir.
DAL_ERP_ALLOW_LEGACY_PLAIN_PASSWORD=0
